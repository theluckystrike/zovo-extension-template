{
  "manifest_version": 3,
  "name": "[EXTENSION_NAME]: [Primary Benefit] | Zovo",
  "version": "1.0.0",
  "description": "[Short description under 132 characters - lead with problem/pain point]",

  "permissions": [
    "storage"
  ],

  "action": {
    "default_popup": "popup.html",
    "default_title": "[EXTENSION_NAME]",
    "default_icon": {
      "16": "icons/icon-16.png",
      "48": "icons/icon-48.png",
      "128": "icons/icon-128.png"
    }
  },

  "background": {
    "service_worker": "background.js",
    "type": "module"
  },

  "options_page": "options.html",

  "icons": {
    "16": "icons/icon-16.png",
    "48": "icons/icon-48.png",
    "128": "icons/icon-128.png"
  }
}
